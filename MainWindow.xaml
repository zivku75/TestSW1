<Window x:Class="SystemInfoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SystemInfoApp"
        mc:Ignorable="d"
        Title="System Information" Height="300" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid>
        <StackPanel Margin="20" VerticalAlignment="Top">
            <!-- Time Display -->
            <StackPanel Margin="0,10">
                <Label Content="Time:" FontWeight="Bold" Foreground="#333333"/>
                <TextBlock x:Name="TimeDisplay" Text="00:00:00" FontSize="18" Foreground="#0078D4" FontFamily="Courier New"/>
            </StackPanel>

            <!-- Day Display -->
            <StackPanel Margin="0,10">
                <Label Content="Day:" FontWeight="Bold" Foreground="#333333"/>
                <TextBlock x:Name="DayDisplay" Text="Loading..." FontSize="14" Foreground="#333333"/>
            </StackPanel>

            <!-- Year Display -->
            <StackPanel Margin="0,10">
                <Label Content="Year:" FontWeight="Bold" Foreground="#333333"/>
                <TextBlock x:Name="YearDisplay" Text="Loading..." FontSize="14" Foreground="#333333"/>
            </StackPanel>

            <!-- Local IP Address Display -->
            <StackPanel Margin="0,10">
                <Label Content="Local IP Address:" FontWeight="Bold" Foreground="#333333"/>
                <TextBlock x:Name="IPDisplay" Text="Loading..." FontSize="14" Foreground="#333333" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Color Dropdown -->
            <StackPanel Margin="0,10">
                <Label Content="Select Color:" FontWeight="Bold" Foreground="#333333"/>
                <ComboBox x:Name="ColorComboBox" Height="30" FontSize="12" VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Close Button -->
            <Button x:Name="CloseButton" Content="Close" Height="35" Margin="0,20,0,0" 
                    Background="#0078D4" Foreground="White" FontSize="12" FontWeight="Bold" 
                    Click="CloseButton_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>